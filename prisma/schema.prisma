generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS — must be defined before models that reference them
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  REP
}

enum TeamSize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum LeadVolume {
  UNDER_50
  BETWEEN_50_200
  BETWEEN_200_500
  BETWEEN_500_1000
  OVER_1000
}

enum SalesCycle {
  SAME_DAY
  THREE_DAYS
  TWO_WEEKS
  FOUR_WEEKS
  THREE_MONTHS
  OVER_THREE_MONTHS
}

enum LeadGrade {
  A
  B
  C
  D
  E
  F
}

// Kind of a Score Evolution timeline entry (see LeadScoreEvent).
enum ScoreEventKind {
  CREATED       // lead first entered the system
  ENRICHED      // data fields added/changed (may re-grade)
  ACTIVITY      // a rep logged a call / WhatsApp / response
  GRADE_CHANGE  // grade moved from re-scoring
  WON
  LOST
}

enum WaStage {
  INQUIRY
  DISCUSSION
  NEGOTIATION
  CLOSING
  STALLED
}

enum WinReason {
  COMPETITIVE_PRICE
  BEST_FIT
  REFERRAL_TRUST
  FAST_DELIVERY
  EXISTING_RELATIONSHIP
  OTHER
}

enum LossReason {
  PRICE_TOO_HIGH
  WENT_COMPETITOR
  NO_BUDGET
  NO_RESPONSE
  REQUIREMENT_CHANGED
  WRONG_FIT
  OTHER
}

enum FollowUpType {
  CALL
  WHATSAPP
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  OVERDUE
  SKIPPED
}

enum TemplateType {
  WHATSAPP
  CALL_SCRIPT
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  BOOLEAN
}

enum AttributionType {
  FULL
  CONTRIBUTED
}

enum SignalType {
  // WhatsApp reply time signals
  WA_REPLIED_1H
  WA_REPLIED_4H
  WA_REPLIED_24H
  WA_NO_REPLY
  // WhatsApp conversation tag signals
  WA_TAG_ASKED_PRICING
  WA_TAG_BROCHURE
  WA_TAG_NEGOTIATING
  WA_TAG_COMPARING
  WA_TAG_DECISION_PENDING
  WA_TAG_NOT_SERIOUS
  WA_TAG_GENERAL_CHAT
  WA_TAG_WRONG_NUMBER
  // WhatsApp stage signals
  WA_STAGE_ADVANCED
  WA_STAGE_REGRESSED
  // Call outcome signals
  CALL_ANSWERED_INTERESTED
  CALL_ANSWERED_NOT_INTERESTED
  CALL_ANSWERED_CALLBACK
  CALL_ANSWERED_WRONG_NUMBER
  CALL_NOT_ANSWERED
  CALL_BUSY
  CALL_INVALID
  CALL_VOICEMAIL
  // Inquiry / import-time signals
  INQUIRY_HIGH_SPECIFICITY
  INQUIRY_MED_SPECIFICITY
  SOURCE_BASELINE
  RE_INQUIRY
  // Import inference signals — generated from CSV field data at import time
  IMPORT_HIGH_INTENT // interest_level = High    (+40)
  IMPORT_MEDIUM_INTENT // interest_level = Medium  (+20)
  IMPORT_LOW_INTENT // interest_level = Low     (+5)
  IMPORT_RECENT_CONTACT // last_contact_days 0–1    (+30)
  IMPORT_WARM_CONTACT // last_contact_days 2–3    (+15)
  IMPORT_STALE_CONTACT // last_contact_days > 5    (-20)
  IMPORT_ACTIVE_INTEREST // notes: demo/call/callback (+30)
  IMPORT_NEGATIVE_SIGNAL // notes: not interested / no response (-25)
  // Behavioural signals
  INQUIRY_EVENING_WEEKEND

  STAGE_PROPOSAL_SENT
  EMAIL_OPENED
  EMAIL_CLICKED
  // Rep override signals
  REP_VERY_INTERESTED
  REP_NOT_INTERESTED
  // System signals
  INTENT_DECAY
}

enum NotifType {
  AT_RISK // lead approaching missed threshold
  FOLLOW_UP_DUE // follow-up action went overdue
  MISSED // lead was marked missed
  RECOVERY // missed lead with recovery potential
  EXEC_SCORE_LOW // rep's daily execution score < 25% at 3pm IST
  REP_SCORE_DROP // rep's 5-component rep score dropped 10+ pts WoW (future use)
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Account {
  id               String     @id @default(cuid())
  name             String
  industry         String
  city             String
  state            String
  team_size        TeamSize
  monthly_lead_vol LeadVolume
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  // ICP Configuration
  icp_configured     Boolean    @default(false)
  icp_industries     String[]   @default([])
  icp_states         String[]   @default([])
  icp_business_types String[]   @default([])
  icp_roles          String[]   @default([])
  icp_budget_min     Int?
  icp_budget_max     Int?
  icp_sales_cycle    SalesCycle @default(FOUR_WEEKS)

  // SQL Threshold (configurable per account)
  sql_fit_threshold    Int @default(55)
  sql_intent_threshold Int @default(45)

  // Signal weight overrides (null = use system defaults)
  weight_overrides Json?

  // Signup attribution (captured at register; null when not provided)
  signup_utm_source   String?
  signup_utm_campaign String?
  signup_country      String?
  signup_ip           String?

  // Razorpay Customer entity id (cust_xxx). Created lazily on first checkout so
  // repeat upgrades reuse the same customer and saved payment methods.
  razorpay_customer_id String?

  // Relations
  users             User[]
  leads             Lead[]
  sources           LeadSource[]
  templates         SmartTemplate[]
  pipeline_stages   PipelineStage[]
  custom_fields     CustomField[]
  follow_up_configs FollowUpConfig[]
  notifications     Notification[]
  workspaces        Workspace[]

  @@map("accounts")
}

// A Workspace is a self-contained lead-intelligence environment within an
// account (flat — never nested). Each owns its own leads, pipeline, sources,
// templates, follow-up configs, custom fields, team membership and analytics.
// ICP/SQL scoring stays at the account level (one shared scoring brain).
model Workspace {
  id          String    @id @default(cuid())
  account_id  String
  name        String
  slug        String
  description String?
  color       String?
  is_default  Boolean   @default(false)
  archived_at DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  account Account           @relation(fields: [account_id], references: [id])
  members WorkspaceMember[]

  @@unique([account_id, slug])
  @@index([account_id])
  @@map("workspaces")
}

// Pure assignment of a User to a Workspace. The user's ACCOUNT role
// (ADMIN/MANAGER/REP) governs what they can do inside any workspace.
model WorkspaceMember {
  id           String   @id @default(cuid())
  workspace_id String
  user_id      String
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id])
  @@index([user_id])
  @@map("workspace_members")
}

// Fixed-window API rate limiter (DB-backed so it works across serverless
// instances). One row per (limiter key); the count resets when the window
// elapses. See lib/rate-limit.ts.
model RateLimit {
  key          String   @id
  count        Int      @default(0)
  window_start DateTime @default(now())

  @@map("rate_limits")
}

model User {
  id         String    @id @default(cuid())
  account_id String
  auth_id    String    @unique // Supabase auth.users.id
  email      String
  first_name String
  last_name  String
  role       UserRole
  is_active  Boolean   @default(true)
  invited_by String?
  invited_at DateTime?
  joined_at  DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  account           Account           @relation(fields: [account_id], references: [id])
  assigned_leads    Lead[]            @relation("AssignedRep")
  signals           Signal[]
  notes             LeadNote[]
  win_attributions  WinAttribution[]
  workspace_members WorkspaceMember[]

  @@unique([account_id, email])
  @@index([account_id])
  @@map("users")
}

model Lead {
  id              String  @id @default(cuid())
  account_id      String
  workspace_id    String?
  assigned_rep_id String?

  // Identity
  first_name   String
  last_name    String?
  phone        String // Stored as +91XXXXXXXXXX
  phone_raw    String // Original value before normalisation
  email        String?
  company_name String?
  designation  String?
  city         String?
  state        String?
  pincode      String?

  // Source & Import
  source_id      String
  import_job_id  String?
  imported_at    DateTime @default(now())
  // Approximate date the SOURCE data was collected (set from the import's
  // "how old is this list?" answer). Null = unspecified → freshness falls back
  // to imported_at. Lets a year-old list imported today read as stale, not new.
  source_collected_at DateTime?
  inquiry_text   String?
  expected_value Int? // INR

  // Three-dimensional scores (0–100)
  fit_score     Int       @default(0)
  intent_score  Int       @default(0)
  quality_score Int       @default(0)
  grade         LeadGrade @default(E)

  // Score metadata
  fit_score_breakdown     Json?
  intent_score_baseline   Int        @default(0)
  quality_score_breakdown Json?
  grade_changed_at        DateTime?
  previous_grade          LeadGrade?

  // SQL status
  is_sql         Boolean   @default(false)
  sql_crossed_at DateTime?
  handoff_brief  String?

  // Speed to Lead (ML data — PRD Constraint 5)
  first_contact_at    DateTime?
  speed_to_lead_hours Float?

  // Recommendation Adoption (North Star): the lead's 1-based rank in its
  // assigned rep's priority queue at the moment of first contact. <= TOP_N
  // means the rep worked a recommended (top-of-queue) lead. Null = never
  // contacted, or contacted while unassigned.
  first_action_rank Int?

  // Pipeline
  stage_id         String
  stage_entered_at DateTime @default(now())
  stage_reason     String? // why the stage last changed (auto-set by system)

  // Flags
  is_junk               Boolean  @default(false)
  junk_flags            String[] @default([])
  is_fatigued           Boolean  @default(false)
  fatigue_contact_count Int      @default(0)
  is_duplicate          Boolean  @default(false)

  // Missed opportunity tracking
  last_action_at DateTime? // when rep last called or messaged
  is_missed      Boolean   @default(false)
  missed_at      DateTime? // when Inngest marked it missed

  // WhatsApp conversation tracking
  wa_conversation_stage WaStage @default(INQUIRY)

  // Won / Lost outcome
  won_at           DateTime?
  lost_at          DateTime?
  won_value        Int?
  win_reason       WinReason?
  loss_reason      LossReason?
  outcome_snapshot Json?

  // Custom field values
  custom_values Json @default("{}")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  account           Account          @relation(fields: [account_id], references: [id])
  assigned_rep      User?            @relation("AssignedRep", fields: [assigned_rep_id], references: [id])
  source            LeadSource       @relation(fields: [source_id], references: [id])
  stage             PipelineStage    @relation(fields: [stage_id], references: [id])
  import_job        ImportJobStatus? @relation(fields: [import_job_id], references: [id])
  signals           Signal[]
  notes             LeadNote[]
  follow_up_actions FollowUpAction[]
  win_attributions  WinAttribution[]
  stage_history     StageHistory[]
  notifications     Notification[]
  score_events      LeadScoreEvent[]

  @@unique([account_id, phone])
  @@index([account_id])
  @@index([workspace_id])
  @@index([workspace_id, assigned_rep_id])
  @@index([workspace_id, stage_id])
  @@index([workspace_id, is_sql])
  @@index([workspace_id, imported_at])
  @@index([workspace_id, is_junk])
  @@map("leads")
}

model Signal {
  id           String  @id @default(cuid())
  account_id   String
  workspace_id String?
  lead_id      String
  user_id      String?

  signal_type  SignalType
  signal_value Float
  raw_value    Json?

  // Context for Phase 2 ML
  lead_grade_at_signal LeadGrade
  intent_score_before  Int
  intent_score_after   Int

  created_at DateTime @default(now())

  lead Lead  @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user User? @relation(fields: [user_id], references: [id])

  @@index([lead_id])
  @@index([lead_id, created_at])
  @@index([account_id])
  @@index([account_id, created_at])
  @@index([workspace_id, created_at])
  @@map("signals")
}

model LeadNote {
  id         String   @id @default(cuid())
  lead_id    String
  user_id    String
  content    String
  created_at DateTime @default(now())

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id])

  @@index([lead_id])
  @@map("lead_notes")
}

model PipelineStage {
  id            String  @id @default(cuid())
  account_id    String
  workspace_id  String?
  name          String
  key           String
  display_order Int
  is_terminal   Boolean @default(false)
  is_won        Boolean @default(false)
  is_lost       Boolean @default(false)

  account Account @relation(fields: [account_id], references: [id])
  leads   Lead[]

  @@unique([workspace_id, key])
  @@index([workspace_id])
  @@map("pipeline_stages")
}

model StageHistory {
  id            String   @id @default(cuid())
  lead_id       String
  from_stage_id String?
  to_stage_id   String
  changed_by    String
  note          String?
  created_at    DateTime @default(now())

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
  @@map("stage_history")
}

// Score Evolution timeline — one append-only entry per meaningful change to a
// lead's grade/confidence (creation, enrichment, activity, re-grade, outcome).
// Each row freezes a snapshot so the timeline is self-contained and confidence
// history (which is otherwise computed on the fly) becomes durable.
model LeadScoreEvent {
  id           String         @id @default(cuid())
  account_id   String
  workspace_id String?
  lead_id      String
  kind         ScoreEventKind
  occurred_at  DateTime       @default(now())

  // Frozen snapshot at this point in time
  grade         LeadGrade
  confidence    Int            // 0–100 (computeConfidence at this moment)
  fit_score     Int
  intent_score  Int
  quality_score Int

  summary String  // human reason, e.g. "Company added" / "CEO responded" / "Grade C → B"
  detail  Json?   // optional structured context (fields_added[], signal_type, …)

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id, occurred_at])
  @@map("lead_score_events")
}

model FollowUpAction {
  id               String         @id @default(cuid())
  account_id       String
  workspace_id     String?
  lead_id          String
  assigned_rep_id  String
  day_number       Int
  action_type      FollowUpType
  due_date         DateTime
  status           FollowUpStatus @default(PENDING)
  completed_at     DateTime?
  completed_by     String?
  is_overdue       Boolean        @default(false)
  escalation_count Int            @default(0) // how many times this follow-up has gone overdue
  show_tip         Boolean        @default(false)
  tip_text         String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
  @@index([account_id, due_date])
  @@index([workspace_id, due_date])
  @@index([assigned_rep_id, due_date])
  @@map("follow_up_actions")
}

model FollowUpConfig {
  id           String    @id @default(cuid())
  account_id   String
  workspace_id String?
  grade        LeadGrade
  schedule     Json
  updated_at   DateTime  @updatedAt

  account Account @relation(fields: [account_id], references: [id])

  @@unique([workspace_id, grade])
  @@map("follow_up_configs")
}

model LeadSource {
  id                String  @id @default(cuid())
  account_id        String
  workspace_id      String?
  name              String
  key               String
  intent_baseline   Int     @default(10)
  reliability_score Float   @default(100.0)
  is_custom         Boolean @default(false)

  account Account @relation(fields: [account_id], references: [id])
  leads   Lead[]

  @@unique([workspace_id, key])
  @@index([workspace_id])
  @@map("lead_sources")
}

model WinAttribution {
  id               String          @id @default(cuid())
  lead_id          String
  user_id          String
  attribution_type AttributionType
  won_value        Int
  created_at       DateTime        @default(now())

  lead Lead @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id])

  @@map("win_attributions")
}

model SmartTemplate {
  id           String       @id @default(cuid())
  account_id   String
  workspace_id String?
  name         String
  type         TemplateType
  stages       String[]
  grades       LeadGrade[]
  body         String
  is_active    Boolean      @default(true)
  usage_count  Int          @default(0)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  account Account @relation(fields: [account_id], references: [id])

  @@index([workspace_id])
  @@map("smart_templates")
}

model ImportJobStatus {
  id           String       @id @default(cuid())
  account_id   String
  workspace_id String?
  user_id      String
  status       ImportStatus @default(PENDING)

  // Session identity
  name      String?
  file_name String?
  source_id String?

  total_rows        Int @default(0)
  inserted          Int @default(0)
  duplicates        Int @default(0)
  errors            Int @default(0)
  progress_pct      Int @default(0)
  high_intent_count Int @default(0) // leads graded A or B from this import
  total_value       Int @default(0) // sum of expected_value (INR)

  error_detail Json?
  created_at   DateTime  @default(now())
  completed_at DateTime?

  leads Lead[]

  @@index([account_id])
  @@index([workspace_id])
  @@map("import_job_status")
}

model CustomField {
  id            String    @id @default(cuid())
  account_id    String
  workspace_id  String?
  label         String
  key           String
  field_type    FieldType
  options       String[]  @default([])
  display_order Int
  is_required   Boolean   @default(false)

  account Account @relation(fields: [account_id], references: [id])

  @@unique([workspace_id, key])
  @@map("custom_fields")
}

model Notification {
  id           String    @id @default(cuid())
  account_id   String
  workspace_id String?
  user_id      String? // null = visible to all managers; set = specific rep
  lead_id      String?
  type         NotifType
  title        String
  message      String
  priority     String    @default("medium") // high | medium | low
  action_url   String?
  is_read      Boolean   @default(false)
  // Alert feedback (FM-14): dismissing hides the alert + records why, so we can
  // learn which alerts are noise. dismiss_reason e.g. "already_handled" | "not_relevant".
  dismissed_at  DateTime?
  dismiss_reason String?
  created_at   DateTime  @default(now())

  account Account @relation(fields: [account_id], references: [id])
  lead    Lead?   @relation(fields: [lead_id], references: [id], onDelete: SetNull)

  @@index([account_id, is_read, created_at])
  @@index([workspace_id, is_read, created_at])
  @@index([user_id, is_read])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// PLATFORM ADMIN ("Mission Control") — separate from per-account UserRole.ADMIN.
// A PlatformAdmin operates across ALL tenants from admin.leadkaun.com.
// ─────────────────────────────────────────────

enum PlatformRole {
  SUPER_ADMIN // full access incl. impersonation + writes
  SUPPORT     // read-only
}

model PlatformAdmin {
  id              String       @id @default(cuid())
  auth_id         String       @unique // Supabase auth.users.id
  email           String       @unique
  role            PlatformRole @default(SUPPORT)
  is_active       Boolean      @default(true)
  mfa_enrolled_at DateTime?
  last_login_at   DateTime?
  created_at      DateTime     @default(now())

  @@map("platform_admins")
}

// Audit trail for "Login as Customer". Decoupled (string refs, no FKs) so it
// never blocks account/user deletion and survives tenant changes.
model ImpersonationLog {
  id             String    @id @default(cuid())
  admin_auth_id  String
  admin_email    String
  account_id     String
  target_user_id String
  reason         String?
  ip             String?
  started_at     DateTime  @default(now())
  ended_at       DateTime?

  @@index([account_id, started_at])
  @@index([admin_auth_id, started_at])
  @@map("impersonation_logs")
}

// Unified per-account event stream powering the Company Timeline + live activity
// feed in Mission Control. Append-only; written best-effort at key lifecycle
// points (never blocks the core path). Read by the admin panel only.
enum AccountEventType {
  SIGNUP
  ICP_CONFIGURED
  WORKSPACE_CREATED
  WORKSPACE_ARCHIVED
  USER_INVITED
  USER_JOINED
  USER_DEACTIVATED
  IMPORT_COMPLETED
  IMPORT_FAILED
  PLAN_CHANGED
  TRIAL_STARTED
  TRIAL_ENDED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  FEATURE_FLAG_CHANGED
  IMPERSONATED
}

model AccountEvent {
  id            String           @id @default(cuid())
  account_id    String
  workspace_id  String?
  actor_user_id String? // null = system / platform admin
  type          AccountEventType
  summary       String
  detail        Json?
  created_at    DateTime         @default(now())

  @@index([account_id, created_at])
  @@index([type, created_at])
  @@map("account_events")
}

// Email send log — instruments lib/email/send.ts so Mission Control can show
// "emails sent today", deliverability and brief-open rates. opened_at is set by
// the Resend webhook. Best-effort write; never blocks a send.
model EmailLog {
  id          String    @id @default(cuid())
  account_id  String?
  to_email    String
  template    String // "morning_brief" | "recovery_alert" | "welcome_admin" | ...
  subject     String
  provider_id String? // Resend message id
  status      String    @default("sent") // sent | failed
  error       String?
  opened_at   DateTime?
  created_at  DateTime  @default(now())

  @@index([account_id, created_at])
  @@index([template, created_at])
  @@index([status, created_at])
  @@map("email_logs")
}

// Background-job run log — wraps the Inngest functions so Mission Control can
// show cron/queue health (success/failure, duration, last run).
model JobRun {
  id          String    @id @default(cuid())
  function    String
  status      String // running | success | failed
  account_id  String?
  items       Int       @default(0)
  error       String?
  started_at  DateTime  @default(now())
  finished_at DateTime?

  @@index([function, started_at])
  @@index([status, started_at])
  @@map("job_runs")
}

// Per-account feature toggles set from Mission Control. A missing row means the
// feature uses its default (usually ON); a row with enabled=false turns it off
// for that account. Read via lib/feature-flags.ts (neutral helper).
model FeatureFlag {
  id         String   @id @default(cuid())
  account_id String
  key        String // "learning_engine" | "queue" | "pipeline" | "analytics" | "confidence"
  enabled    Boolean  @default(true)
  updated_by String? // platform admin auth_id
  updated_at DateTime @updatedAt

  @@unique([account_id, key])
  @@index([account_id])
  @@map("feature_flags")
}

// ─────────────────────────────────────────────
// BILLING — Razorpay Subscriptions wired; the manual founder path (Company 360
// PlanEditor) still writes the same rows. Provider webhooks are the source of
// truth for status/Payment/Invoice; the manual path stays for edge cases.
// ─────────────────────────────────────────────

model Plan {
  id        String  @id @default(cuid())
  key       String  @unique // trial | starter | growth | scale
  name      String
  price_inr Int     @default(0) // monthly, in paise
  is_active Boolean @default(true)

  // Seat limit for the account. A "seat" is any user row that is not
  // deactivated — see lib/billing/seats.ts. Enforced on invite.
  // free 1 | starter 10 | growth 30 | scale 75 | enterprise effectively ∞
  max_seats Int @default(1)

  // Max ACTIVE leads an account may hold (open leads — not won/lost/junk).
  // Null = unlimited. Soft paywall: at the cap, existing leads stay fully usable
  // and only NEW leads are blocked. Closing/losing a deal frees a slot.
  // See lib/billing/lead-usage.ts. free 100 | starter 5,000 | growth 25,000 |
  // scale/enterprise null (unlimited)
  active_lead_limit Int?

  // Razorpay Plan entity id (plan_xxx). Populated by scripts/razorpay-sync-plans.ts.
  // Null for `trial`/`enterprise` (not sold online) and until the sync has run.
  provider_plan_id String?

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                       String    @id @default(cuid())
  account_id               String    @unique
  plan_id                  String
  status                   String    @default("trialing") // trialing | active | past_due | canceled
  mrr_inr                  Int       @default(0) // in paise; denormalised for quick MRR sums
  trial_ends_at            DateTime?
  started_at               DateTime  @default(now())
  canceled_at              DateTime?
  provider                 String? // razorpay | stripe (null for manually-set plans)
  provider_subscription_id String? // the provider's subscription id (sub_xxx)

  // "Update payment method" re-authorises on a NEW Razorpay subscription (no
  // card-swap API exists). This holds that pending replacement's id until it
  // activates; the webhook then cancels the old sub at cycle end and swaps this
  // into provider_subscription_id.
  pending_provider_subscription_id String?

  // Saved-card display for the billing portal. Captured from the charged
  // webhook's card payment. No PAN/CVV — only the network + last4 Razorpay
  // returns, which are safe to store and show ("Visa •••• 4242").
  card_last4   String?
  card_network String?

  // Billing cycle + the current paid period, so the app can show a renewal date.
  // Period bounds are set from the provider webhook (subscription.charged).
  // Seat/lead LIMITS are NOT stored here — they live on Plan (active_lead_limit,
  // max_seats) so a plan change updates every subscriber at once, no backfill.
  billing_cycle        String? // monthly | annual
  current_period_start DateTime?
  current_period_end   DateTime?

  plan Plan @relation(fields: [plan_id], references: [id])

  @@index([status])
  // Webhooks arrive keyed by the provider's subscription id, never by account.
  @@index([provider_subscription_id])
  @@map("subscriptions")
}

model Payment {
  id           String   @id @default(cuid())
  account_id   String
  amount_inr   Int // in paise
  status       String   @default("succeeded") // succeeded | failed | refunded
  provider     String?
  provider_ref String?
  created_at   DateTime @default(now())

  @@index([account_id, created_at])
  @@index([status, created_at])
  // Razorpay retries webhooks on non-2xx. Without this, a retried
  // subscription.charged writes the payment twice and inflates revenue.
  // Postgres treats NULLs as distinct, so manual rows (provider_ref = null)
  // are unaffected.
  @@unique([provider, provider_ref])
  @@map("payments")
}

model Invoice {
  id           String    @id @default(cuid())
  account_id   String
  number       String?
  amount_inr   Int
  status       String    @default("paid") // paid | open | void
  period_start DateTime?
  period_end   DateTime?
  pdf_url      String?
  provider     String?
  provider_ref String?
  created_at   DateTime  @default(now())

  @@index([account_id, created_at])
  @@unique([provider, provider_ref]) // same retry-idempotency reason as Payment
  @@unique([number]) // consecutive serial (invoice_serial_seq); no duplicates
  @@map("invoices")
}

// Razorpay delivers at-least-once and retries for up to 24h. We record every
// event id we have fully processed so a retry is a cheap no-op instead of a
// duplicate write. Rows are safe to prune after ~30 days.
model WebhookEvent {
  id           String   @id @default(cuid())
  provider     String // razorpay
  event_id     String // x-razorpay-event-id header
  event_type   String // subscription.charged, etc.
  processed_at DateTime @default(now())

  @@unique([provider, event_id])
  @@index([processed_at])
  @@map("webhook_events")
}

// Daily "what should I do today?" digest for Mission Control. Computed by an
// Inngest cron and stored so the dashboard can show today's snapshot + history.
model AdminInsight {
  id         String   @id @default(cuid())
  for_date   String // YYYY-MM-DD (IST)
  items      Json // Insight[] — { label, count, severity, href? }
  created_at DateTime @default(now())

  @@unique([for_date])
  @@map("admin_insights")
}
