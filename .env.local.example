# Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@leadkaun.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google Sheets
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay — use rzp_test_* keys locally, NEVER rzp_live_*.
# WEBHOOK_SECRET is set when you create the webhook in the Razorpay Dashboard
# (Settings → Webhooks). It is a separate value from KEY_SECRET.
# After filling these in, run: npx tsx scripts/razorpay-sync-plans.ts
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
